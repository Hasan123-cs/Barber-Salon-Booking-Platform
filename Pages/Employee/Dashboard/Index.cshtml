@page
@model BarberSalon.Pages.Employee.Dashboard.IndexModel
@{
    ViewData["Title"] = "Employee Dashboard";
    Layout = "EmployeeLayout";
}

<div class="container py-5">

    <div class="mb-5">

        <h2 class="fw-bold">
            <i class="bi bi-speedometer2 text-warning"></i>
            Employee Dashboard
        </h2>

        <p class="text-muted">
            Welcome back! Here's your schedule for today.
        </p>

    </div>

    <div class="row g-4 mb-5">

        <div class="col-md-3">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <i class="bi bi-calendar-check display-5 text-primary"></i>

                    <h1 class="mt-3">@Model.TodayCount</h1>

                    <p class="text-muted mb-0">
                        Today's Appointments
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <i class="bi bi-hourglass-split display-5 text-warning"></i>

                    <h1 class="mt-3">@Model.PendingCount</h1>

                    <p class="text-muted mb-0">
                        Pending
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <i class="bi bi-check-circle display-5 text-success"></i>

                    <h1 class="mt-3">@Model.CompletedCount</h1>

                    <p class="text-muted mb-0">
                        Completed
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <i class="bi bi-x-circle display-5 text-danger"></i>

                    <h1 class="mt-3">@Model.CancelledCount</h1>

                    <p class="text-muted mb-0">
                        Cancelled
                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow border-0">

        <div class="card-header bg-warning">

            <h4 class="mb-0">

                Today's Schedule

            </h4>

        </div>

        <div class="card-body">

            @if (Model.TodayAppointments.Any())
            {
                <table class="table table-hover align-middle">

                    <thead>

                        <tr>

                            <th>Time</th>

                            <th>Customer</th>

                            <th>Service</th>

                            <th>Status</th>


                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model.TodayAppointments)
                        {
                            <tr>

                                <td>
                                    @item.StartTime
                                </td>

                                <td>
                                    @item.User.FullName
                                </td>

                                <td>
                                    @item.Service.Name
                                </td>

                                <td>

                                    <span class="badge bg-warning">

                                        @item.Status

                                    </span>

                                </td>

                               

                            </tr>
                        }

                    </tbody>

                </table>
            }
            else
            {
                <div class="text-center py-5">

                    <i class="bi bi-calendar-x display-1 text-secondary"></i>

                    <h4 class="mt-3">

                        No appointments today

                    </h4>

                </div>
            }

        </div>

    </div>

</div>