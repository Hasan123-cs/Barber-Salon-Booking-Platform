<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewBag.Title - Classic Barber</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

            body {
                background-color: #f8f9fa;
            }

            .navbar-brand {
                font-size: 1.5rem;
                font-weight: bold;
            }

            footer a {
                text-decoration: none;
                color: white;
            }

                footer a:hover {
                    color: #ffc107;
                }

    </style>

</head>

<body>

    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">

        <div class="container">

            <a class="navbar-brand" asp-page="/Customer/Home/Index">
                <i class="bi bi-scissors"></i> Classic Barber
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbar">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbar">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Customer/Home/Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Customer/Services/Index">Services</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Customer/Home/Index#cat">Products</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Employees/Index">Our Team</a>
                    </li>

                   

                </ul>

                <ul class="navbar-nav align-items-center">

                

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown">

                                <i class="bi bi-person-circle"></i>
                                My Account

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Identity"
                                       asp-page="/Account/Manage/Index">
                                        <i class="bi bi-person"></i>
                                        Profile
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-page="/Appointments/MyAppointments">
                                        <i class="bi bi-calendar-check"></i>
                                        My Appointments
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-page="/Cart/Index">
                                        <i class="bi bi-cart3"></i>
                                        My Cart
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-page="/Order/History">
                                        <i class="bi bi-box-seam"></i>
                                        My Orders
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>

                                <li>
                                    <form method="post"
                                          
                                          asp-page="/Account/Logout">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right"></i>
                                            Logout
                                        </button>
                                    </form>
                                </li>

                            </ul>

                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-area="Identity"
                               asp-page="/Account/Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-warning ms-2"
                               asp-area="Identity"
                               asp-page="/Account/Register">
                                Register
                            </a>
                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>

    <!-- Page Content -->

    <main class="container my-4">

        @RenderBody()

    </main>

    <!-- Footer -->

    <footer class="bg-dark text-white mt-5">

        <div class="container py-5">

            <div class="row">

                <div class="col-md-4">

                    <h4>Barber Salon</h4>

                    <p>
                        Professional barber and beauty salon services with
                        premium grooming products.
                    </p>

                </div>

                <div class="col-md-4">

                    <h5>Quick Links</h5>

                    <ul class="list-unstyled">

                        <li>
                            <a asp-page="/Index">Home</a>
                        </li>

                        <li>
                            <a asp-page="/Services/Index">Services</a>
                        </li>

                        <li>
                            <a asp-page="/Products/Index">Products</a>
                        </li>

                        <li>
                            <a asp-page="/Employees/Index">Our Team</a>
                        </li>

                    </ul>

                </div>

                <div class="col-md-4">

                    <h5>Contact</h5>

                    <p>📍 Beirut, Lebanon</p>

                    <p>📞 +961 xx xxx xxx</p>

                    <p>✉ info@barbersalon.com</p>

                </div>

            </div>

            <hr>

            <div class="text-center">

                © @DateTime.Now.Year Barber Salon. All Rights Reserved.

            </div>

        </div>

    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>