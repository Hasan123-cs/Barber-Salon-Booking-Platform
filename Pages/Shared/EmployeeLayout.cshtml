<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Employee Panel</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/images/barberIcon.png" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" />

    <style>

            body {
                background: #f8f9fa;
            }

            .navbar {
                box-shadow: 0 2px 10px rgba(0,0,0,.08);
            }

            .navbar-brand {
                font-weight: 700;
            }

            .nav-link {
                font-weight: 500;
                transition: .2s;
            }

                .nav-link:hover {
                    color: #ffc107 !important;
                }

            footer {
                background: #212529;
                color: white;
            }

    </style>

</head>

<body>

    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

        <div class="container">

            <a class="navbar-brand"
               asp-page="/Employee/Dashboard/Index">

                <i class="bi bi-scissors text-warning"></i>
                Barber Employee

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarEmployee">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="navbarEmployee">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">

                        <a class="nav-link"
                           asp-page="/Employee/Dashboard/Index">

                            <i class="bi bi-speedometer2"></i>
                            Dashboard

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link"
                           asp-page="/Employee/Appointments/Index">

                            <i class="bi bi-calendar-check"></i>
                            My Appointments

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link"
                           asp-page="/Employee/Schedules/Index">

                            <i class="bi bi-clock-history"></i>
                            My Schedule

                        </a>

                    </li>

                    

                </ul>

                <form method="post" asp-page="/Account/Logout">

                    <button class="btn btn-outline-warning">

                        <i class="bi bi-box-arrow-right"></i>
                        Logout

                    </button>

                </form>

            </div>

        </div>

    </nav>

    <!-- Content -->

    <main class="container py-4">

        @RenderBody()

    </main>

    <!-- Footer -->
    <!-- Avoid the Footer in  My Appointments -->
    @if (!(ViewData["HideFooter"] as bool? ?? false))
        {
            <footer class="py-3 mt-5">

                <div class="container text-center">

                    <small>

                        © @DateTime.Now.Year Barber Salon Employee Panel

                    </small>

                </div>

            </footer>
        }
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>