@page
@model BarberSalon.Pages.Account.RegisterModel
@{
    Layout = null;
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<body class="bg-dark">
<div class=" container vh-100 d-flex align-items-center justify-content-center">

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden"
         style="max-width:950px;width:100%;">

        <div class="row g-0">

            <div class="col-lg-5 bg-dark text-white d-none d-lg-flex
                flex-column justify-content-center align-items-center p-5" style="background-color:black !important">

                <div class="bg-warning rounded-circle d-flex
                    justify-content-center align-items-center mb-4"
                     style="width:90px;height:90px;">

                    <i class="bi bi-scissors fs-1 text-dark"></i>

                </div>


                <h2 class="fw-bold">
                    Classic Barber
                </h2>

                <p class="text-center text-secondary mt-3">
                    Create your account and enjoy premium grooming services.
                </p>



            </div>



            <div class="col-lg-7 bg-white p-5">


                <h3 class="fw-bold mb-2">
                    Create Account
                </h3>

                <p class="text-muted mb-4">
                    Join our barber salon community
                </p>


                <form method="post">
                    @if(!ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="bg-danger text-white"></div>
                    }

                    <div class="mb-3">

                        <label class="form-label fw-semibold">
                            Full Name
                        </label>

                        <div class="input-group">

                            <span class="input-group-text bg-white">
                                <i class="bi bi-person"></i>
                            </span>

                            <input type="text"
                                   class="form-control"
                                   asp-for="bind.FullName"
                                   placeholder="Enter your name">
                        </div>
                                   <span asp-validation-for="bind.FullName" class="text-danger" ></span>

                    </div>



                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label class="form-label fw-semibold">
                                Email
                            </label>

                            <div class="input-group">

                                <span class="input-group-text bg-white">
                                    <i class="bi bi-envelope"></i>
                                </span>

                                <input type="email"
                                       class="form-control"
                                       asp-for="bind.Email"
                                       placeholder="Email">

                            </div>
                                    <span asp-validation-for="bind.Email" class="text-danger"></span>

                        </div>


                        <div class="col-md-6 mb-3">

                            <label class="form-label fw-semibold">
                                Phone
                            </label>

                            <div class="input-group">

                                <span class="input-group-text bg-white">
                                    <i class="bi bi-telephone"></i>
                                </span>

                                <input type="text"
                                    asp-for="bind.PhoneNumber"
                                       class="form-control"
                                       placeholder="Phone">


                            </div>
                                    <span asp-validation-for="bind.PhoneNumber" class="text-danger"></span>

                        </div>

                    </div>




                    




                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label class="form-label fw-semibold">
                                Password
                            </label>

                            <div class="input-group">

                                <span class="input-group-text bg-white">
                                    <i class="bi bi-lock"></i>
                                </span>

                                <input type="password"
                                    asp-for="bind.Password"
                                       class="form-control"
                                       placeholder="Password">


                            </div>
                                    <span asp-validation-for="bind.Password" class="text-danger"></span>

                        </div>



                        <div class="col-md-6 mb-3">

                            <label class="form-label fw-semibold">
                                Confirm Password
                            </label>

                            <div class="input-group">

                                <span class="input-group-text bg-white">
                                    <i class="bi bi-lock-fill"></i>
                                </span>

                                <input type="password"
                                       class="form-control"
                                       asp-for="bind.ConfirmPassword"
                                       placeholder="Confirm">


                            </div>
                                    <span asp-validation-for="bind.ConfirmPassword" class="text-danger"></span>

                        </div>

                    </div>




                    <div class="form-check mb-4">

                        <input class="form-check-input"
                                   name="IAgree"
                                   value="true"
                               type="checkbox">

                        <label class="form-check-label">

                            I agree with terms and conditions

                        </label>

                    </div>



                    <div class="d-grid">

                        <button class="btn btn-warning btn-lg fw-semibold">

                            <i class="bi bi-person-plus me-2"></i>

                            Create Account

                        </button>

                    </div>



                    <p class="text-center mt-4 mb-0">

                        Already have an account?

                        <a href="/Account/Login"
                           class="text-decoration-none fw-semibold">

                            Login

                        </a>

                    </p>


                </form>


            </div>


        </div>

    </div>

</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
</body>