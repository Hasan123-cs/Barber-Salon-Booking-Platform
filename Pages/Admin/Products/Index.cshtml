@page
@model BarberSalon.Pages.Admin.Products.IndexModel
@{
    ViewData["Title"] = "Product Management";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Product Management</h2>

        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Product
        </a>
    </div>

    <div class="card shadow">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th style="width:180px;">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Products.Any())
                    {
                        foreach (var item in Model.Products)
                        {
                            <tr>

                                <td style="width:90px;">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl"
                                             class="rounded border"
                                             width="70"
                                             height="70"
                                             style="object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <img src="https://www.shutterstock.com/shutterstock/photos/1827776723/display_1500/stock-vector-icon-of-no-link-disconnected-symbol-vector-1827776723.jpg"
                                             class="rounded border"
                                             width="70"
                                             height="70"
                                             style="object-fit:cover;" />
                                    }
                                </td>

                                <td>@item.Name</td>

                                <td>@item.Category.Name</td>

                                <td>$@item.Price</td>

                                <td>@item.StockStatus</td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>

                                <td>

                                    <a asp-page="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <form method="post"
                                          asp-page-handler="ToggleStatus"
                                          asp-route-id="@item.Id"
                                          class="d-inline">

                                        <button type="submit"
                                                class="btn btn-sm @(item.IsActive ? "btn-danger" : "btn-success")">

                                            @(item.IsActive ? "Disable" : "Enable")

                                        </button>

                                    </form>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">
                                No products found.
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>