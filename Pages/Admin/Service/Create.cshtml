@page
@model BarberSalon.Pages.Admin.Service.CreateModel
@{
    ViewData["Title"] = "Add Service";
    Layout = "AdminLayout";
}

<div class="container py-4">

    <div class="card shadow">

        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">
                <i class="bi bi-scissors"></i>
                Add Service
            </h3>
        </div>

        <div class="card-body">

            <form method="post" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Service.Name" class="form-label"></label>
                    <input asp-for="Service.Name" class="form-control" />
                    <span asp-validation-for="Service.Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Service.Description" class="form-label"></label>
                    <textarea asp-for="Service.Description"
                              class="form-control"
                              rows="4"></textarea>
                    <span asp-validation-for="Service.Description" class="text-danger"></span>
                </div>

                <div class="row">

                    <div class="col-md-6">

                        <label asp-for="Service.Price" class="form-label"></label>

                        <input asp-for="Service.Price"
                               class="form-control" />

                        <span asp-validation-for="Service.Price"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="Service.Duration"
                               class="form-label"></label>

                        <input asp-for="Service.Duration"
                               class="form-control" />

                        <span asp-validation-for="Service.Duration"
                              class="text-danger"></span>

                    </div>

                </div>

                <div class="mt-3">

                    <label class="form-label">Service Image</label>

                    <input asp-for="ServiceImage"
                           type="file"
                           class="form-control" />

                </div>

                <div class="form-check mt-3">

                    <input asp-for="Service.IsActive"
                           class="form-check-input" />

                    <label asp-for="Service.IsActive"
                           class="form-check-label">
                    </label>

                </div>

                <div class="mt-4">

                    <button type="submit"
                            class="btn btn-success">

                        <i class="bi bi-check-circle"></i>
                        Create Service

                    </button>

                    <a asp-page="Index"
                       class="btn btn-secondary">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}