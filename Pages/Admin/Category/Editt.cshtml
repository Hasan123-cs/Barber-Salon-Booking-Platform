@page "{ids:int}"
@model BarberSalon.Pages.Admin.Category.EdittModel

@{
    ViewData["Title"] = "Edit Category";
    Layout = "AdminLayout";

}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-warning">
            <h4 class="mb-0">Edit Category</h4>
        </div>

        <div class="card-body">

            <form method="post">

                <input type="hidden" asp-for="id" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">
                    <label asp-for="Category.Name" class="form-label"></label>

                    <input asp-for="Category.Name"
                           class="form-control" />

                    <span asp-validation-for="Category.Name"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Category.Description"
                           class="form-label"></label>

                    <textarea asp-for="Category.Description"
                              class="form-control"
                              rows="4"></textarea>

                    <span asp-validation-for="Category.Description"
                          class="text-danger"></span>
                </div>

                <div class="form-check mb-4">

                    <input asp-for="Category.IsActive"
                           class="form-check-input" />

                    <label asp-for="Category.IsActive"
                           class="form-check-label">
                        Active
                    </label>

                </div>

                <button type="submit"
                        class="btn btn-warning text-white">
                    Update
                </button>

                <a asp-page="/Admin/Category/Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}