@page
@model BarberSalon.Pages.Admin.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "AdminLayout";

}
@using System.Text.Json
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="/css/AdminDashboard.css" rel="stylesheet" />


<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="dashboard-title">
                Dashboard
            </h2>

            <p class="text-muted">
                Welcome back @Model.userName
            </p>

        </div>

        <button class="btn btn-primary">

            <i class="fa-solid fa-calendar"></i>

            Today

        </button>

    </div>

    <div class="row">

        <div class="col-lg-3 col-md-6 mb-4">

            <div class="card card-stat shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h6 class="text-muted">

                                Customers

                            </h6>

                            <h2>

                                 @Model.Customers

                            </h2>

                        </div>

                        <div class="icon-box bg-blue">

                            <i class="fa-solid fa-users"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6 mb-4">

            <div class="card card-stat shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h6 class="text-muted">

                                Employees

                            </h6>

                            <h2>

                                @Model.Employees 

                            </h2>

                        </div>

                        <div class="icon-box bg-green">

                            <i class="fa-solid fa-user-tie"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6 mb-4">

            <div class="card card-stat shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h6 class="text-muted">

                                Orders

                            </h6>

                            <h2>

                                 @Model.Orders 

                            </h2>

                        </div>

                        <div class="icon-box bg-orange">

                            <i class="fa-solid fa-cart-shopping"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6 mb-4">

            <div class="card card-stat shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h6 class="text-muted">

                                Revenue

                            </h6>

                            <h2>

                               $@Model.Revenue

                            </h2>

                        </div>

                        <div class="icon-box bg-danger2">

                            <i class="fa-solid fa-dollar-sign"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="row">

        <div class="col-lg-8 mb-4">

            <div class="card chart-card">

                <div class="card-header bg-white">

                    <h5>

                        Monthly Revenue

                    </h5>

                </div>

                <div class="card-body">

                    <canvas id="RevenueChart">



                    </canvas>

                </div>

            </div>

        </div>

        <div class="col-lg-4 mb-4">

            <div class="card chart-card">

                <div class="card-header bg-white">

                    <h5>

                        Appointment Status

                    </h5>

                </div>

                <div class="card-body">

                    <canvas id="StatusChart"></canvas>

                </div>

            </div>

        </div>

    </div>

    <div class="row">

        <div class="col-lg-6 mb-4">

            <div class="card chart-card">

                <div class="card-header bg-white">

                    <h5>

                        Most Booked Services

                    </h5>

                </div>

                <div class="card-body">

                    <canvas id="ServiceChart"></canvas>

                </div>

            </div>

        </div>

        <div class="col-lg-6 mb-4">

            <div class="card chart-card">

                <div class="card-header bg-white">

                    <h5>

                        Top Employees

                    </h5>

                </div>

                <div class="card-body">

                    <canvas id="EmployeeChart"></canvas>

                </div>

            </div>

        </div>

    </div>

 

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // why i do json serialize ? java script not understand the list of string c# so transform to json
    // to understand it by js
    const labels =@Html.Raw(JsonSerializer.Serialize(Model.RevenueLabels));
    const revenue =@Html.Raw(JsonSerializer.Serialize(Model.RevenueData));
    const appointmentLabels =@Html.Raw(JsonSerializer.Serialize(Model.AppointmentLabels));
    const appointmentData =@Html.Raw(JsonSerializer.Serialize(Model.AppointmentData));

    const ctx =document.getElementById('RevenueChart');

    new Chart(ctx,{

    type:'line',

    data:{

    labels:labels,

    datasets:[{

    label:'Revenue',

    data:revenue,

    borderWidth:3,

    fill:true,

    tension:.4

    }]

    }

    });
    // appointment status 

    const statusCtx =document.getElementById('StatusChart');

    new Chart(statusCtx,{

    type:'doughnut',

    data:{

    labels: appointmentLabels,

    datasets:[{

    data: appointmentData,

    borderWidth:1

    }]

    },

    options:{

    responsive:true,

    plugins:{

    legend:{

    position:'bottom'

    }

    }

    }

    });

    // Most Booked Services

    const serviceLabels =@Html.Raw(JsonSerializer.Serialize(Model.ServiceLabels));


    const serviceData =@Html.Raw(JsonSerializer.Serialize(Model.ServiceData));


    const serviceCtx =document.getElementById('ServiceChart');


    new Chart(serviceCtx,{

    type:'bar',

    data:{

    labels:serviceLabels,

    datasets:[{

    label:'Bookings',

    data:serviceData,

    borderWidth:1

    }]

    },

    options:{

    responsive:true,

    plugins:{

    legend:{

    display:false

    }

    }

    }

    });
    // Top Employees

    const employeeLabels =
    @Html.Raw(JsonSerializer.Serialize(Model.EmployeeLabels));


    const employeeData =
    @Html.Raw(JsonSerializer.Serialize(Model.EmployeeData));


    const employeeCtx =
    document.getElementById('EmployeeChart');


    new Chart(employeeCtx,{

    type:'bar',

    data:{

    labels:employeeLabels,

    datasets:[{

    label:'Appointments',

    data:employeeData,

    borderWidth:1,
    backgroundColor:[
    '#4e73df',
    '#1cc88a',
    '#36b9cc',
    '#f6c23e',
    '#e74a3b'
    ],

    borderColor:[
    '#4e73df',
    '#1cc88a',
    '#36b9cc',
    '#f6c23e',
    '#e74a3b'
    ]


    }]

    },

    options:{

    responsive:true,

    plugins:{

    legend:{

    display:false

    }

    }

    }

    });
</script>