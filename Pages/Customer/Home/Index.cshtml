@page
@model BarberSalon.Pages.Home.IndexModel

@{
    ViewData["Title"] = "Home";
    Layout = "HomeLayout";
}

@* <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"> *@

<link rel="stylesheet" href="/css//HomePage.css" />

<!-- HERO -->

<div class="container mt-4" style="background-image: url('/images/barber.jpg')">

<div class="hero d-flex align-items-center">

<div class="ms-5">

<h1 class="display-3 fw-bold">
Fresh Style.<br />
Fresh Confidence.
</h1>

<p class="lead mt-3">
Professional barber and beauty salon services with premium grooming products.
</p>

<a class="btn btn-pink btn-lg me-3">
Book Appointment
</a>

<a class="btn btn-light btn-lg">
Shop Products
</a>

</div>

</div>

</div>
<!-- CATEGORYS -->
<div id="cat" class="container mt-5">

    <h2 class="section-title text-center">
        Categories
    </h2>

    <div class="row g-4">
        @foreach (var category in Model.Categories)
        {
            <div class="col-md-3">

                <div class="card text-center">

                    <div class="card-body">

                        <h4>
                            @category.Name
                        </h4>

                        <p>
                            @category.Description
                        </p>

                        <a class="btn btn-pink"
                           asp-page="/Category/Index"
                           asp-route-categoryId="@category.Id">
                            Browse
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>


<!-- SERVICES -->

<div class="container mt-5">

<h2 class="section-title text-center">
Popular Services
</h2>

<div class="row g-4">

<div class="col-md-4">

<div class="card service-card">

<img src="/images/haircut.jpg" class="card-img-top">

<div class="card-body">

<h4>Hair Cut</h4>

<p>
Professional haircut by experienced barber.
</p>

<div class="d-flex justify-content-between">

<span class="fw-bold text-danger">
$15
</span>

<span>
30 Minutes
</span>

</div>

<a class="btn btn-pink w-100 mt-3">
Book Now
</a>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card service-card">

<img src="/images/beard.jpg" class="card-img-top">

<div class="card-body">

<h4>Beard Trim</h4>

<p>
Clean and stylish beard trimming.
</p>

<div class="d-flex justify-content-between">

<span class="fw-bold text-danger">
$10
</span>

<span>
20 Minutes
</span>

</div>

<a class="btn btn-pink w-100 mt-3">
Book Now
</a>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card service-card">

<img src="/images/color.jpg" class="card-img-top">

<div class="card-body">

<h4>Hair Coloring</h4>

<p>
Premium coloring with high quality products.
</p>

<div class="d-flex justify-content-between">

<span class="fw-bold text-danger">
$40
</span>

<span>
90 Minutes
</span>

</div>

<a class="btn btn-pink w-100 mt-3">
Book Now
</a>

</div>

</div>

</div>

</div>

</div>

<!-- EMPLOYEES -->

<div class="container mt-5">

<h2 class="section-title text-center">
Meet Our Professionals
</h2>
@foreach(var staff in Model.bestEmployee )
    {

<div class="col-md-4">

<div class="card employee-card text-center">

<img src="/images/@staff.ImageUrl" class="card-img-top">

<div class="card-body">

<h4>@staff.Name</h4>

<p class="text-muted">
@staff.Specialization
</p>

<p>

@staff.ExperienceYears Years Experience

</p>

<a class="btn btn-outline-pink">
View Schedule
</a>

</div>

</div>

</div>
        
    }


</div>
    
@* </div> *@
    
