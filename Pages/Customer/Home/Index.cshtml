@page
@model BarberSalon.Pages.Home.IndexModel

@{
    ViewData["Title"] = "Home";
    Layout = "HomeLayout";
}

@* <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"> *@

<link rel="stylesheet" href="/css//HomePage.css" />

<!-- HERO -->

<div class="container mt-4" style="background-image: url('/images/barber.jpg')">

<div class="hero d-flex align-items-center">

<div class="ms-5">

<h1 class="display-3 fw-bold">
Fresh Style.<br />
Fresh Confidence.
</h1>

<p class="lead mt-3">
Professional barber and beauty salon services with premium grooming products.
</p>

<a class="btn btn-pink btn-lg me-3" href="/Customer/Services/Index">
Book Appointment
</a>

<a class="btn btn-light btn-lg" href="#cat">
Shop Products
</a>

</div>

</div>

</div>
<!-- CATEGORYS -->
<div id="cat" class="container mt-5">

    <h2 class="section-title text-center">
        Categories
    </h2>

    <div class="row g-4">
        @foreach (var category in Model.Categories)
        {
            <div class="col-md-3">

                <div class="card text-center">

                    <div class="card-body">

                        <h4>
                            @category.Name
                        </h4>

                        <p>
                            @category.Description
                        </p>

                        <a class="btn btn-pink"
                           asp-page="/Category/Index"
                           asp-route-categoryId="@category.Id">
                            Browse
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>


<!-- SERVICES -->

<!-- EMPLOYEES -->
<div class="container mt-5">

    <h2 class="section-title text-center mb-4">
        Meet Our Professionals
    </h2>

    <div class="row g-4">

        @foreach (var staff in Model.bestEmployee)
        {
            <div class="col-md-4">

                <div class="card employee-card text-center h-100">

                    <img src="/images/@staff.ImageUrl" class="card-img-top" alt="@staff.Name">

                    <div class="card-body">

                        <h4>@staff.Name</h4>

                        <p class="text-muted">
                            @staff.Specialization
                        </p>

                        <p>
                            @staff.ExperienceYears Years Experience
                        </p>

                      

                    </div>

                </div>

            </div>
        }

    </div>

</div>
    
@* </div> *@
    
