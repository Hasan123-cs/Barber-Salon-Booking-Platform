@page
@model BarberSalon.Pages.Customer.Services.IndexModel

@{
    ViewData["Title"] = "Services";
    Layout = "HomeLayout";
}

<div class="container p-0" >

    <!-- Hero Section -->
    <section class="bg-dark text-white text-center py-5 ">
        <div class="container-fluid py-5">

            <h1 class="display-4 fw-bold">
                Premium Barber Services
            </h1>

            <p class="lead text-light mt-3">
                Experience professional grooming with expert barbers,
                premium products, and modern techniques.
            </p>

            <a href="#services"
               class="btn btn-warning btn-lg mt-4 px-5">
                Explore Services
            </a>

        </div>
    </section>


    <!-- Services in db -->

    <section id="services" class="container py-5">

        <div class="text-center mb-5">

            <h2 class="fw-bold">
                Our Services
            </h2>

            <p class="text-muted">
                Choose the perfect grooming service.
            </p>

        </div>

        <div class="row g-4">

            @foreach (var item in Model.Services)
            {
                <div class="col-lg-4 col-md-6">

                    <div class="card border-0 shadow service-card h-100">

                        <img src="@item.ImageUrl"
                             class="card-img-top service-image"
                             alt="@item.Name">

                        <div class="card-body">

                            <h4 class="fw-bold">

                                @item.Name

                            </h4>

                            <p class="text-muted">

                                @item.Description

                            </p>

                            <div class="d-flex justify-content-between mt-4">

                                <span>

                                    ⏱ @item.Duration Minutes

                                </span>

                                <span class="fw-bold text-warning">

                                    $@item.Price

                                </span>

                            </div>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <a asp-page="/Customer/Services/Details"
                               asp-route-id="@item.Id"
                               class="btn btn-dark w-100">

                                View Details

                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </section>


    <!-- why choose us -->

    <section class="bg-light py-5">

        <div class="container">

            <div class="text-center mb-5">

                <h2 class="fw-bold">
                    Why Choose Us
                </h2>

            </div>

            <div class="row text-center">

                <div class="col-md-3">

                    <i class="bi bi-scissors display-4 text-warning"></i>

                    <h5 class="mt-3">
                        Expert Barbers
                    </h5>

                    <p class="text-muted">
                        Skilled professionals with years of experience.
                    </p>

                </div>

                <div class="col-md-3">

                    <i class="bi bi-award display-4 text-warning"></i>

                    <h5 class="mt-3">
                        Premium Quality
                    </h5>

                    <p class="text-muted">
                        High-quality grooming products.
                    </p>

                </div>

                <div class="col-md-3">

                    <i class="bi bi-clock display-4 text-warning"></i>

                    <h5 class="mt-3">
                        Fast Service
                    </h5>

                    <p class="text-muted">
                        Always on time with online booking.
                    </p>

                </div>

                <div class="col-md-3">

                    <i class="bi bi-star display-4 text-warning"></i>

                    <h5 class="mt-3">
                        Customer Satisfaction
                    </h5>

                    <p class="text-muted">
                        Hundreds of happy customers.
                    </p>

                </div>

            </div>

        </div>

    </section>




    <section class="bg-dark text-white text-center py-5">

        <div class="container">

            <h2 class="fw-bold">

                Ready for a Fresh Look?

                
            </h2>

            <p class="lead">

                Discover our professional barber services
                and book your next visit today.

            </p>

            <a href="#services" class="btn btn-warning btn-lg">
                Browse Services

            </a>

        </div>

    </section>

</div>