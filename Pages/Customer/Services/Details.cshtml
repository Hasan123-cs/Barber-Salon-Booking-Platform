@page "{id:int}"

@model BarberSalon.Pages.Customer.Services.DetailsModel

@{
    ViewData["Title"] = "Service Details";
    Layout = "HomeLayout";
}


<div class="container py-5">


    <div class="row align-items-center">

        <!-- Imagesn -->

        <div class="col-md-6">

            <img src="@Model.Service.ImageUrl"
                 class="img-fluid rounded shadow"
                 alt="@Model.Service.Name" />

        </div>



        <!-- Information -->

        <div class="col-md-6">


            <h1 class="fw-bold">
                @Model.Service.Name
            </h1>


            <p class="text-muted mt-3">
                @Model.Service.Description
            </p>



            <div class="mt-4">


                <h5>
                    ⏱ Duration:
                    <span class="text-muted">
                        @Model.Service.Duration Minutes
                    </span>
                </h5>



                <h5 class="mt-3">
                    💰 Price:
                    <span class="text-warning">
                        $@Model.Service.Price
                    </span>
                </h5>


            </div>



            <a asp-page="/Customer/Appointment"
               asp-route-serviceId="@Model.Service.Id"
               class="btn btn-warning btn-lg mt-4 px-5">

                Book Now

            </a>



            <a asp-page="/Customer/Services/Index"
               class="btn btn-dark btn-lg mt-4 ms-2">

                Back

            </a>


        </div>


    </div>


</div>