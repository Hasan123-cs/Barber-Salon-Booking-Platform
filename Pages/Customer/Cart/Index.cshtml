@page
@model BarberSalon.Pages.Customer.Cart.IndexModel
@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "HomeLayout";
}
<!-- UI PHASE (use here because is small not big to use seperated Css file  ) -->
<style>

    body {
        background: #f8f9fa;
    }

    .card {
        border-radius: 18px;
    }

    .btn-warning {
        font-weight: 600;
    }

    img {
        transition: .3s;
    }

    .card:hover img {
        transform: scale(1.03);
    }

</style>
<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-cart3 text-warning"></i>
                Shopping Cart
            </h2>

            <p class="text-muted mb-0">
                Review your selected products before checkout.
            </p>
        </div>

        <a asp-page="/Customer/Home/Index"
           class="btn btn-outline-dark rounded-pill">

            <i class="bi bi-arrow-left"></i>
            Continue Shopping

        </a>

    </div>

    <div class="row g-4">

        <!-- Cart Items -->
        <div class="col-lg-8">

            @if (Model.CartItems.Any())
            {
                @foreach (var item in Model.CartItems)
                {
                    <div class="card shadow-sm border-0 rounded-4 mb-4">

                        <div class="card-body">

                            <div class="row align-items-center">

                                <div class="col-md-3">

                                    <img src="@item.ImageUrl"
                                         class="img-fluid rounded-3"
                                         style="height:150px;width:100%;object-fit:cover;">

                                </div>

                                <!-- Product -->
                                <div class="col-md-4">

                                    <h5 class="fw-bold">
                                        @item.Name
                                    </h5>

                                    <h4 class="text-warning fw-bold mt-3">
                                        $@item.Price
                                    </h4>

                                </div>

                                <!-- Quantity -->
                                <div class="col-md-3">

                                    <form method="post" asp-page-handler="Update">

                                        <input type="hidden"
                                               name="productId"
                                               value="@item.ProductId" />

                                        <label class="form-label fw-semibold">
                                            Quantity
                                        </label>

                                        <input type="number"
                                               name="quantity"
                                               value="@item.Quantity"
                                               min="1"
                                               class="form-control mb-2" />

                                        <button type="submit"
                                                class="btn btn-warning text-white w-100">

                                            Update Quantity

                                        </button>

                                    </form>

                                </div>

                                <!-- Remove -->
                                <form method="post" asp-page-handler="Remove">

                                    <input type="hidden"
                                           name="productId"
                                           value="@item.ProductId" />

                                    <div class="col-md-2 text-end">

                                        <h5 class="fw-bold">
                                            $@(item.Price * item.Quantity)
                                        </h5>

                                        <button type="submit" class="btn btn-outline-danger mt-3">
                                            <i class="bi bi-trash"></i>
                                        </button>

                                    </div>

                                </form>
                            </div>

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="card border-0 shadow rounded-4">

                    <div class="card-body text-center py-5">

                        <i class="bi bi-cart-x display-1 text-warning"></i>

                        <h3 class="mt-3">
                            Your Cart is Empty
                        </h3>

                        <p class="text-muted">
                            Add some products to start shopping.
                        </p>

                        <a asp-page="/Customer/Home/Index"
                           class="btn btn-warning">

                            Shop Now

                        </a>

                    </div>

                </div>
            }

        </div>

        <!-- Summary -->
        <div class="col-lg-4">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body">

                    <h4 class="fw-bold mb-4">
                        Order Summary
                    </h4>

                    <div class="d-flex justify-content-between mb-3">

                        <span>Products</span>

                        <strong>
                            @Model.CartItems.Count
                        </strong>

                    </div>

                    <div class="d-flex justify-content-between mb-3">

                        <span>Subtotal</span>

                        <strong>
                            $@Model.SubTotal
                        </strong>

                    </div>

                    <div class="d-flex justify-content-between mb-3">

                        <span>Shipping</span>

                        <span class="text-success">
                            FREE
                        </span>

                    </div>

                    <hr>

                    <div class="d-flex justify-content-between fs-4">

                        <strong>Total</strong>

                        <strong class="text-warning">
                            $@Model.SubTotal
                        </strong>

                    </div>
                    <a asp-page="/Customer/Checkout/Index"
                       class="btn btn-warning btn-lg w-100 mt-4">

                        <i class="bi bi-credit-card"></i>
                        Checkout

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>


